# Copy to .env and fill in. Only the daemon (deploy/docker-compose.yml) reads this.
# Secrets only — no quotes needed.

# --- required ---
GITHUB_REPO=owner/name
GITHUB_TOKEN=ghp_xxx                     # needs pull-requests:write

# --- provider: local (free, needs a GPU box running llama.cpp llama-server) ---
PROVIDER=local
LLAMA_SERVER_URL=http://host.docker.internal:8080

# --- provider: openrouter (paid, no GPU) — swap the two lines above for these ---
# PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-xxx
# MODEL=z-ai/glm-5.2

# --- optional ---
# K=                                     # passes to union (default 1 openrouter / 3 local)
# MERGE_PROVIDER=                        # default = PROVIDER (local => fully offline)
# MERGE_MODEL=                           # default = the review model
# GUIDANCE_FILE=.github/review-guidance.md
# TOOLS=read,bash                        # set `read` to drop the agent's shell
# INTERVAL=1800                          # seconds between sweeps
